  ami        ="ami_00fa32593b478ad6e"
# 1. Define the Provider
provider "aws" {
  region = "ap-south-1"
}

# 2. Your S3 Bucket (from Phase 1)
resource "aws_s3_bucket" "my_first_bucket" {
  bucket = "my-unique-s3-bucket-12-june-2026-yourname" # Remember to keep this unique!
}

# 3. Dynamic AMI Lookup (Data Source)
data "aws_ami" "amazon_linux" {
  most_recent = true
  owners      = ["amazon"]

  filter {
    name   = "name"
    values = ["al2023-ami-2023.*-x86_64"]
  }
}

# 4. Your EC2 Instance (New for Phase 2)
resource "aws_instance" "my_first_server" {
  ami           = data.aws_ami.amazon_linux.id
  instance_type = "t2.micro"

  tags = {
    Name = "My-Terraform-Server"
  }
}   instance_type ="t2.micro"
   
    tags={
       Name="My-Terraform-Server"
    }
}
